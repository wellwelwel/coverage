{
  "name": "@pokujs/coverage",
  "private": false,
  "version": "0.4.0",
  "description": "☔️ The world's first V8 and JSC coverage tool to generate reports for Node.js, Bun, Deno, and TypeScript at the same time.",
  "type": "module",
  "main": "./lib/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pokujs/coverage.git"
  },
  "homepage": "https://poku.io/docs/documentation/helpers/coverage",
  "bugs": {
    "url": "https://github.com/pokujs/coverage/issues"
  },
  "author": "https://github.com/wellwelwel",
  "funding": {
    "type": "github",
    "url": "https://github.com/pokujs/coverage?sponsor=1"
  },
  "files": [
    "lib",
    "resources"
  ],
  "engines": {
    "node": ">=18.x.x"
  },
  "scripts": {
    "build": "tsx tools/build.ts",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit",
    "build:snapshots": "cross-env UPDATE_SNAPSHOTS=1 npm test",
    "postbuild:snapshots": "tsx tools/postbuild-snapshots.ts",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .github/workflows/*.yml .",
    "pretest": "npm run build",
    "test": "poku",
    "test:node": "npm run test -- -t=\"node:\"",
    "test:deno": "npm run test -- -t=\"deno:\"",
    "test:bun": "npm run test -- -t=\"bun:\"",
    "update": "pu && npm i && npm update && (npm audit fix || true)",
    "postupdate": "npm run lint:fix"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "jsonc.min": "^1.1.2",
    "toml.min": "^1.0.0",
    "yaml.min": "^1.0.0"
  },
  "peerDependencies": {
    "poku": "^4.3.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/lcov-parse": "^1.0.2",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "domhandler": "^6.0.1",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.0",
    "fast-xml-parser": "^5.7.1",
    "htmlparser2": "^12.0.0",
    "lcov-parse": "^1.0.0",
    "packages-update": "^2.0.0",
    "poku": "^4.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "🐷",
    "poku",
    "pokujs",
    "testing",
    "plugin",
    "coverage",
    "v8",
    "jsc",
    "javascriptcore",
    "lcov",
    "istanbul",
    "javascript",
    "node",
    "node.js",
    "bun",
    "oven-bun",
    "bun.sh",
    "deno",
    "cross-runtime",
    "cross-platform",
    "interoperability",
    "codecov",
    "codacy",
    "lcovonly",
    "text-lcov",
    "text-summary",
    "teamcity",
    "json",
    "json-summary",
    "cobertura",
    "clover",
    "none",
    "text",
    "yaml",
    "yml",
    "toml",
    "jsonc",
    "nyc",
    "c8",
    "monocart-coverage-reports",
    "one-double-zero"
  ]
}
